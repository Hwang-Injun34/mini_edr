{
  "groups": {
    "HttpClient": [
      "curl",
      "wget",
      "python",
      "python3"
    ],

    "AbnormalPort": [
      4444,
      8081,
      8443,
      9001
    ]
  },

  "rules": [
    {
      "rule_id": "DET0027_AN0076",
      "name": "비정상 포트를 사용하는 HTTP 클라이언트 연결 탐지",
      "description": "curl, wget, Python 등의 HTTP 클라이언트가 비정상 포트로 네트워크 연결을 생성하는 행위를 탐지한다.",
      "event_type": "NetworkConnect",
      "syscall": "connect",

      "conditions": {
        "exe": "HttpClient",
        "dest_port": "AbnormalPort"
      }
    }
  ]
}